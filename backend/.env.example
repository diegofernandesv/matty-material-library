# Database connection string for Supabase PostgreSQL
# Format: postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:6543/postgres
# Find in Supabase: Connect > Connection String > Transaction pooler
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres"

# Supabase project URL
# Find in Supabase: Project Settings > API > Project URL
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"

# Supabase anonymous key (safe to use server-side for token verification)
# Find in Supabase: Project Settings > API > Project API keys > anon public
SUPABASE_ANON_KEY="your-anon-key-here"

# OpenAI API key for GPT-4o
# Get from https://platform.openai.com/ > API Keys
OPENAI_API_KEY="your-openai-api-key-here"

# Server port (optional, defaults to 3000)
PORT=3000
